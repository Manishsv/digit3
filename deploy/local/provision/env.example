# Full stack + tenant + sample complaint:
#   ../up-and-provision.sh   (from provision/: cd .. && ./up-and-provision.sh)
#
# Tenant only (stack already up):
#   ./run-full-provision.sh
#   # auth-server / changeme, superuser = TENANT_EMAIL / default
#
# Manual path — copy to env.provision and source before each script:
#   cp env.example env.provision
#   set -a && source env.provision && set +a
#
# Suggested order:
#   1. ./account-setup.sh              → tenant; then set KEYCLOAK_REALM + Keycloak OAuth client
#   2. ./account-setup.sh --platform-only   → boundaries, core registry, registryId idgen
#   3. ./service-setup.sh              → MDMS, case-type registry, filestore category, workflow
#   4. ./onboarding.sh                 → realm roles + users (CSV optional)
#   5. ./service-test.sh               → smoke checks

# --- Keycloak (token + admin API for digit user/role commands) ---
KEYCLOAK_ORIGIN=http://localhost:8080
KEYCLOAK_REALM=

# Password-grant client in tenant realm (used by all scripts that need JWT)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_USERNAME=
OAUTH_PASSWORD=

# --- Account API (tenant only; no JWT) ---
ACCOUNT_BASE_URL=http://localhost:8094
ACCOUNT_X_CLIENT_ID=test-client
TENANT_NAME=
TENANT_EMAIL=
TENANT_CODE=

# --- Service base URLs (local compose defaults) ---
WORKFLOW_BASE_URL=http://localhost:8085
MDMS_BASE_URL=http://localhost:8099
BOUNDARY_BASE_URL=http://localhost:8093
REGISTRY_BASE_URL=http://localhost:8104
FILESTORE_BASE_URL=http://localhost:8102
IDGEN_BASE_URL=http://localhost:8100
NOTIFICATION_BASE_URL=http://localhost:8091

# --- Account / platform (boundaries + core registry) ---
# CORE_BOUNDARIES_FILE=          # default: digit-cli example-boundaries.yaml
# CORE_REGISTRY_SCHEMA_FILE=     # default: provision/examples/core-registry-schema.yaml

# --- Service setup (module / case) ---
# DIGIT_EXAMPLES_DIR=/path/to/digit-cli
# MDMS_SCHEMA_FILE=
# MDMS_DATA_FILE=
# CASE_REGISTRY_SCHEMA_FILE=     # default: provision/examples/case-registry-schema.yaml
# WORKFLOW_FILE=

# --- Onboarding ---
# Space-separated realm roles to create (default: CITIZEN CSR GRO LME)
# ONBOARDING_ROLES=CITIZEN CSR GRO LME
# CSV: username,password,email,roles  (roles pipe-separated, e.g. GRO|CSR)
# ONBOARDING_USERS_CSV=./onboarding-users.csv

# --- service-test.sh ---
# REGISTRY_TEST_SCHEMA=complaints.case
# REGISTRY_WRITE_SMOKE=0   # set to 0 to skip POST row after schema check

# --- create-complaint.sh (workflow + registry when REGISTRY_BASE_URL set) ---
# REGISTRY_CASE_SCHEMA=complaints.case
# COMPLAINT_SKIP_REGISTRY=1
