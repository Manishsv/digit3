              "body": {
                "mode": "raw",
                "raw": "{\n    \"messages\": [\n        //it will create new message\n        {\n            \"code\": \"new.code\",\n            \"message\": \"New message via upsert daf\",\n            \"module\": \"common\",\n            \"locale\": \"en\"\n        },\n\n        //it will update existing message\n        {\n            \"uuid\": \"63368dfd-6579-4357-b51a-da5d29766078\",\n            \"code\": \"goodbye.msg\",\n            \"message\": \"Thank you for using our app. \",\n            \"module\": \"common\",\n            \"locale\": \"en\"\n        }\n    ]\n}"
