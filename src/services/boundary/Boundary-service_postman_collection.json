							"    pm.expect(responseData.responseInfo).to.exist;\r",
							"    pm.expect(responseData.responseInfo).to.have.all.keys('apiId', 'ver', 'ts', 'status');\r",
							"});\r",
							"\r",
							"\r",
							"pm.test(\"The tenantBoundary array is present and contains at least one element\", function () {\r",
							"    const responseData = pm.response.json();\r",
