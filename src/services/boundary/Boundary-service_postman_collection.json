							"});\r",
							"\r",
							"\r",
							"pm.test(\"Response contains required properties\", function () {\r",
							"    const responseData = pm.response.json();\r",
							"    \r",
							"    pm.expect(responseData).to.be.an('object');\r",
							"    pm.expect(responseData.responseInfo).to.exist;\r",
							"    pm.expect(responseData.tenantBoundary).to.be.an('array').that.is.not.empty;\r",
							"\r",
							"    responseData.tenantBoundary.forEach(function(tenant) {\r",
