				"body": {
					"mode": "raw",
					"raw": "{\n  \"templateId\": \"user-details\",\n  \"fieldMapping\": {\n    \"name\": \"$.user.name\",\n    \"age\": \"$.user.age\"\n  },\n  \"apiMapping\": [\n    {\n      \"method\": \"GET\",\n      \"endpoint\": {\n        \"base\": \"https://jsonplaceholder.typicode.com\",\n        \"path\": \"/{{resources}}/{{id}}\",\n        \"pathParams\": {\n          \"resources\": \"$.resources\",\n          \"id\": \"$.id\"\n        }\n      },\n      \"responseMapping\": {\n        \"userId\":\"$.userId\",\n        \"title\": \"$.title\"\n      }\n    }\n  ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8092/template-config/v1/config",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8092",
					"path": [
